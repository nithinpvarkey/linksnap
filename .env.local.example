# LinkSnap Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Generated in Phase 4 — leave blank until then
SNAPGIF_SECRET=generate_when_building_phase_4

# Railway URL — added after Phase 6 deploy
SNAPGIF_SERVICE_URL=get_after_railway_deploy_phase_6
